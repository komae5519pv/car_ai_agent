{
  "datasets": [
    {
      "name": "dbee0df1",
      "displayName": "店舗日次データ",
      "queryLines": [
        "SELECT\n",
        "    store_name,\n",
        "    region,\n",
        "    store_lat,\n",
        "    store_lon,\n",
        "    vehicle_category,\n",
        "    activity_date,\n",
        "    revenue,\n",
        "    contracts,\n",
        "    inquiries\n",
        "FROM konomi_demo_catalog.car_ai_demo.gd_store_daily_activity\n",
        "-- WHERE YEAR(activity_date) = 2026"
      ],
      "columns": [
        {
          "displayName": "成約率",
          "description": "成約数 ÷ 接客数",
          "expression": "SUM(contracts) / NULLIF(SUM(inquiries), 0)"
        }
      ]
    },
    {
      "name": "0792f51a",
      "displayName": "店舗日次データ (Forecasted)",
      "queryLines": [
        "WITH original_table AS (\n",
        "    SELECT \n",
        "  DATE_TRUNC(\"MONTH\", `activity_date`) AS activity_date,\n",
        "  SUM(`revenue`) AS revenue\n",
        "FROM (\n",
        "    SELECT\n",
        "    store_name,\n",
        "    region,\n",
        "    store_lat,\n",
        "    store_lon,\n",
        "    vehicle_category,\n",
        "    activity_date,\n",
        "    revenue,\n",
        "    contracts,\n",
        "    inquiries\n",
        "FROM konomi_demo_catalog.car_ai_demo.gd_store_daily_activity\n",
        "-- WHERE YEAR(activity_date) = 2026\n",
        ") GROUP BY 1\n",
        "  ),\n",
        "  dates AS (\n",
        "    SELECT \n",
        "      MAX(activity_date) AS max_date_column,\n",
        "      MIN(activity_date) AS min_date_column,\n",
        "      MAX_BY(revenue, activity_date) AS revenue\n",
        "    FROM original_table\n",
        "  ),\n",
        "  forecast_table AS (\n",
        "    SELECT \n",
        "      activity_date,\n",
        "      revenue_forecast,\n",
        "      revenue_upper,\n",
        "      revenue_lower,\n",
        "      NULL AS revenue\n",
        "    FROM AI_FORECAST(\n",
        "      TABLE(original_table),\n",
        "      horizon => (\n",
        "        SELECT\n",
        "          max_date_column + MAKE_DT_INTERVAL(CAST(FLOOR(DATEDIFF(max_date_column, min_date_column) * 0.5) AS INT), 0, 0, 0)\n",
        "        FROM dates\n",
        "      ),\n",
        "      time_col => 'activity_date',\n",
        "      value_col => 'revenue'\n",
        "    )\n",
        "  )\n",
        "\n",
        "  SELECT * FROM forecast_table\n",
        "  UNION ALL\n",
        "  SELECT\n",
        "    activity_date,\n",
        "    NULL AS revenue_forecast,\n",
        "    NULL AS revenue_upper,\n",
        "    NULL AS revenue_lower,\n",
        "    revenue\n",
        "  FROM original_table\n",
        "    WHERE activity_date < (SELECT max_date_column FROM dates)\n",
        "  UNION ALL\n",
        "  SELECT\n",
        "    max_date_column AS activity_date,\n",
        "    revenue AS revenue_forecast,\n",
        "    revenue AS revenue_upper,\n",
        "    revenue AS revenue_lower,\n",
        "    revenue\n",
        "  FROM\n",
        "    dates"
      ],
      "columns": [
        {
          "displayName": "成約率",
          "description": "成約数 ÷ 接客数",
          "expression": "SUM(contracts) / NULLIF(SUM(inquiries), 0)"
        }
      ]
    }
  ],
